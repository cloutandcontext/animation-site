---
interface Props {
  variant?: 'badge' | 'wordmark';
  class?: string;
}
const { variant = 'badge', class: className = '' } = Astro.props;
---

{
  variant === 'badge' ? (
    <span class={`logo-badge ${className}`} aria-label="Clout & Context">
      <svg width="36" height="36" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg" role="img">
        <defs>
          <linearGradient id="logoGradient" x1="0" y1="0" x2="36" y2="0" gradientUnits="userSpaceOnUse">
            <stop offset="0" stop-color="#00E8F8" />
            <stop offset="0.5" stop-color="#B048D8" />
            <stop offset="1" stop-color="#F81878" />
          </linearGradient>
        </defs>
        <path d="M10 4L4 10V26L10 32" stroke="url(#logoGradient)" stroke-width="2.5" stroke-linecap="round" />
        <path d="M26 4L32 10V26L26 32" stroke="url(#logoGradient)" stroke-width="2.5" stroke-linecap="round" />
        <text x="18" y="23" text-anchor="middle" font-family="Space Grotesk, sans-serif" font-weight="700" font-size="14" fill="#FFFFFF">C&amp;C</text>
      </svg>
    </span>
  ) : (
    <span class={`logo-wordmark ${className}`}>
      <span class="logo-wordmark-text">CLOUT<span class="logo-amp">&amp;</span>CONTEXT</span>
      <span class="logo-swoosh" aria-hidden="true" />
    </span>
  )
}

<style>
  .logo-badge {
    display: inline-flex;
    line-height: 0;
  }

  .logo-wordmark {
    display: inline-flex;
    flex-direction: column;
    gap: var(--space-2);
    font-family: var(--font-display);
  }

  .logo-wordmark-text {
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  .logo-amp {
    background: var(--gradient-brand);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    padding-inline: 0.15em;
  }

  .logo-swoosh {
    display: block;
    height: 4px;
    width: 100%;
    max-width: 220px;
    border-radius: 2px;
    background: var(--gradient-brand);
  }
</style>
