---
interface Props {
  variant?: 'badge' | 'wordmark';
  class?: string;
}
const { variant = 'badge', class: className = '' } = Astro.props;
---

{
  variant === 'badge' ? (
    <img
      src="/logos/logo-circle.png"
      alt="Clout & Context"
      class={`logo-badge ${className}`}
      width="512"
      height="512"
      decoding="async"
    />
  ) : (
    <img
      src="/logos/logo-wordmark.png"
      alt="Clout & Context"
      class={`logo-wordmark ${className}`}
      width="805"
      height="399"
      decoding="async"
    />
  )
}

<style>
  .logo-badge {
    display: block;
    width: 40px;
    height: 40px;
  }

  .logo-wordmark {
    display: block;
    width: 100%;
    max-width: 240px;
    height: auto;
  }
</style>
