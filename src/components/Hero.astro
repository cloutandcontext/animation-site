---
import type { Platform } from '../data/work';

interface Props {
  platform: Platform;
  id: string;
  orientation?: 'landscape' | 'portrait';
}
const { platform, id, orientation = 'landscape' } = Astro.props;
const poster = platform === 'youtube' ? `https://i.ytimg.com/vi/${id}/maxresdefault.jpg` : null;
const posterStyle = poster ? `background-image: url(${poster});` : undefined;
---

{
  orientation === 'portrait' ? (
    <section class="hero hero-portrait">
      <div class="hero-glow" aria-hidden="true" />
      <div class="container hero-grid">
        <div class="hero-copy">
          <p class="eyebrow">Cinematic animation for UK artists &amp; creators</p>
          <h1>Animated music videos and social clips for UK artists &amp; creators.</h1>
          <div class="hero-actions">
            <a href="#work" class="btn btn-primary">See the work</a>
            <a href="#contact" class="btn btn-secondary">Start a project</a>
          </div>
        </div>

        <div class="hero-video-col">
          <div class="hero-media-portrait" data-hero-media data-platform={platform} data-id={id}>
            <div class="hero-poster" data-hero-poster aria-hidden="true" style={posterStyle} />
          </div>
          <button type="button" class="sound-toggle" data-sound-toggle aria-pressed="false">
            <span data-sound-label>Sound off</span>
          </button>
        </div>
      </div>
    </section>
  ) : (
    <section class="hero hero-landscape">
      <div class="hero-media" data-hero-media data-platform={platform} data-id={id}>
        <div class="hero-poster" data-hero-poster aria-hidden="true" style={posterStyle} />
      </div>
      <div class="hero-overlay" aria-hidden="true" />
      <div class="container hero-content">
        <p class="eyebrow">Cinematic animation for UK artists &amp; creators</p>
        <h1>Animated music videos and social clips for UK artists &amp; creators.</h1>
        <div class="hero-actions">
          <a href="#work" class="btn btn-primary">See the work</a>
          <a href="#contact" class="btn btn-secondary">Start a project</a>
        </div>
      </div>
      <button type="button" class="sound-toggle sound-toggle-float" data-sound-toggle aria-pressed="false">
        <span data-sound-label>Sound off</span>
      </button>
    </section>
  )
}

<style>
  .hero {
    position: relative;
    overflow: hidden;
    background: var(--c-black);
  }

  .eyebrow {
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--c-cyan);
    margin-bottom: var(--space-4);
  }

  .hero-actions {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .sound-toggle {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    background: rgba(10, 10, 10, 0.6);
    border: 1px solid var(--c-border);
    color: var(--c-white);
    border-radius: 999px;
    padding: 0.6em 1.1em;
    font-size: 0.85rem;
    cursor: pointer;
    backdrop-filter: blur(6px);
  }

  .sound-toggle[hidden] {
    display: none;
  }

  .sound-toggle:hover {
    border-color: var(--c-cyan);
  }

  /* ---------- Portrait (vertical video) hero ---------- */
  .hero-portrait {
    min-height: 88vh;
    display: flex;
    align-items: center;
    padding-block: var(--space-16);
  }

  .hero-glow {
    position: absolute;
    inset: 0;
    z-index: 0;
    background: radial-gradient(circle at 15% 20%, rgba(0, 232, 248, 0.14), transparent 55%),
      radial-gradient(circle at 90% 80%, rgba(248, 24, 120, 0.14), transparent 55%), var(--c-black);
  }

  .hero-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: var(--space-12);
    align-items: center;
  }

  .hero-copy h1 {
    margin-bottom: var(--space-8);
  }

  .hero-video-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  .hero-media-portrait {
    position: relative;
    width: 100%;
    max-width: 300px;
    aspect-ratio: 9 / 16;
    border-radius: 20px;
    overflow: hidden;
    border: 1px solid var(--c-border);
    background: #000;
    box-shadow: 0 24px 70px rgba(0, 0, 0, 0.55);
  }

  /* A vertical video embeds pillar-boxed inside YouTube's 16:9 player;
     over-size the iframe so the centred vertical strip fills the frame
     and the black bars overflow out of the clipped container. */
  .hero-media-portrait :global(iframe) {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    height: 100%;
    width: 316%; /* (16/9)^2 */
    border: 0;
    pointer-events: none;
  }

  .hero-poster {
    position: absolute;
    inset: 0;
    background-color: #000;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  /* ---------- Landscape (full-bleed background) hero ---------- */
  .hero-landscape {
    min-height: 92vh;
    display: flex;
    align-items: flex-end;
  }

  .hero-media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-media :global(iframe) {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 100vw;
    height: 56.25vw;
    min-height: 100%;
    min-width: 177.78vh;
    transform: translate(-50%, -50%);
    border: 0;
    pointer-events: none;
  }

  .hero-landscape .hero-poster::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 30% 20%, rgba(0, 232, 248, 0.12), transparent 55%),
      radial-gradient(circle at 80% 70%, rgba(248, 24, 120, 0.12), transparent 55%);
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(180deg, rgba(10, 10, 10, 0.6) 0%, rgba(10, 10, 10, 0.55) 40%, rgba(10, 10, 10, 0.92) 100%);
  }

  .hero-content {
    position: relative;
    z-index: 2;
    padding-bottom: var(--space-24);
    max-width: 760px;
  }

  .hero-content h1 {
    margin-bottom: var(--space-8);
  }

  .sound-toggle-float {
    position: absolute;
    z-index: 2;
    right: var(--space-6);
    bottom: var(--space-6);
  }

  @media (max-width: 820px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .hero-video-col {
      order: -1;
    }

    .hero-media-portrait {
      max-width: 260px;
    }
  }

  @media (max-width: 640px) {
    .hero-landscape {
      min-height: 78vh;
    }
  }
</style>

<script>
  function initHero() {
    const media = document.querySelector<HTMLElement>('[data-hero-media]');
    const toggleBtn = document.querySelector<HTMLButtonElement>('[data-sound-toggle]');
    const label = document.querySelector<HTMLElement>('[data-sound-label]');
    if (!media || media.dataset.bound) return;
    media.dataset.bound = '1';

    const platform = media.dataset.platform;
    const videoId = media.dataset.id;
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // Respect reduced motion: leave the static poster, no autoplaying video.
    if (reduceMotion || !videoId) {
      toggleBtn?.setAttribute('hidden', '');
      return;
    }

    let player: any = null;
    let ready = false;
    const win = window as any;

    function mountVimeo() {
      const iframe = document.createElement('iframe');
      iframe.src = `https://player.vimeo.com/video/${videoId}?background=0&muted=1&loop=1&controls=0&autoplay=1&title=0&byline=0&portrait=0`;
      iframe.allow = 'autoplay; fullscreen';
      iframe.setAttribute('title', 'Clout & Context showreel');
      media!.appendChild(iframe);
      const script = document.createElement('script');
      script.src = 'https://player.vimeo.com/api/player.js';
      script.onload = () => {
        player = new win.Vimeo.Player(iframe);
        ready = true;
      };
      document.body.appendChild(script);
    }

    function mountYouTube() {
      const iframe = document.createElement('iframe');
      iframe.id = 'hero-yt-player';
      const origin = encodeURIComponent(location.origin);
      iframe.src =
        `https://www.youtube-nocookie.com/embed/${videoId}` +
        `?autoplay=1&mute=1&loop=1&playlist=${videoId}&controls=0&rel=0` +
        `&modestbranding=1&playsinline=1&iv_load_policy=3&disablekb=1&fs=0&enablejsapi=1&origin=${origin}`;
      iframe.allow = 'autoplay; fullscreen; encrypted-media';
      iframe.setAttribute('title', 'Clout & Context showreel');
      media!.appendChild(iframe);

      const makePlayer = () => {
        player = new win.YT.Player('hero-yt-player', {
          events: { onReady: () => (ready = true) },
        });
      };
      if (win.YT && win.YT.Player) {
        makePlayer();
      } else {
        const script = document.createElement('script');
        script.src = 'https://www.youtube.com/iframe_api';
        document.body.appendChild(script);
        win.onYouTubeIframeAPIReady = makePlayer;
      }
    }

    function mount() {
      if (platform === 'vimeo') mountVimeo();
      else mountYouTube();
    }

    if ('IntersectionObserver' in window) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              mount();
              observer.disconnect();
            }
          });
        },
        { threshold: 0.1 }
      );
      observer.observe(media);
    } else {
      mount();
    }

    toggleBtn?.addEventListener('click', () => {
      if (!player || !ready) return;
      const isPressed = toggleBtn.getAttribute('aria-pressed') === 'true';
      const setLabel = () => {
        toggleBtn.setAttribute('aria-pressed', String(!isPressed));
        if (label) label.textContent = isPressed ? 'Sound off' : 'Sound on';
      };

      if (platform === 'vimeo') {
        player.setMuted(isPressed).then(setLabel);
      } else {
        if (isPressed) {
          player.mute?.();
        } else {
          player.unMute?.();
          player.setVolume?.(100);
        }
        setLabel();
      }
    });
  }

  initHero();
  document.addEventListener('astro:page-load', initHero);
</script>
