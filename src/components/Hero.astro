---
import type { Platform } from '../data/work';

interface VideoRef {
  platform: Platform;
  id: string;
}

interface Props {
  platform: Platform;
  id: string;
  orientation?: 'landscape' | 'portrait' | 'combined';
  /** Portrait overlay video, used only when orientation is 'combined'. */
  overlay?: VideoRef;
}
const { platform, id, orientation = 'landscape', overlay } = Astro.props;

const yt = (v: string) => ({
  max: `https://i.ytimg.com/vi/${v}/maxresdefault.jpg`,
  fb: `https://i.ytimg.com/vi/${v}/mqdefault.jpg`,
});
const bg = platform === 'youtube' ? yt(id) : null;
const ov = overlay && overlay.platform === 'youtube' ? yt(overlay.id) : null;

const copy = {
  eyebrow: 'Cinematic animation for UK artists & creators',
  heading: 'Animated music videos and social clips for UK artists & creators.',
};
---

{
  orientation === 'combined' ? (
    <section class="hero hero-combined" data-hero>
      <div class="hero-media hero-bg" data-hero-media data-platform={platform} data-id={id} data-sound="true">
        {bg && (
          <img class="hero-poster" src={bg.max} alt="" decoding="async" onerror={`this.onerror=null;this.src='${bg.fb}'`} />
        )}
      </div>
      <div class="hero-overlay" aria-hidden="true" />

      <div class="container hero-grid">
        <div class="hero-copy">
          <p class="eyebrow">{copy.eyebrow}</p>
          <h1>{copy.heading}</h1>
          <div class="hero-actions">
            <a href="#work" class="btn btn-primary">See the work</a>
            <a href="#contact" class="btn btn-secondary">Start a project</a>
          </div>
        </div>

        {overlay && (
          <div class="hero-video-col">
            <div class="hero-media-portrait" data-hero-media data-platform={overlay.platform} data-id={overlay.id}>
              {ov && (
                <img class="hero-poster" src={ov.max} alt="" decoding="async" onerror={`this.onerror=null;this.src='${ov.fb}'`} />
              )}
            </div>
          </div>
        )}
      </div>

      <button type="button" class="sound-toggle sound-toggle-float" data-sound-toggle aria-pressed="false">
        <span data-sound-label>Sound off</span>
      </button>
    </section>
  ) : orientation === 'portrait' ? (
    <section class="hero hero-portrait" data-hero>
      <div class="hero-glow" aria-hidden="true" />
      <div class="container hero-grid">
        <div class="hero-copy">
          <p class="eyebrow">{copy.eyebrow}</p>
          <h1>{copy.heading}</h1>
          <div class="hero-actions">
            <a href="#work" class="btn btn-primary">See the work</a>
            <a href="#contact" class="btn btn-secondary">Start a project</a>
          </div>
        </div>

        <div class="hero-video-col">
          <div class="hero-media-portrait" data-hero-media data-platform={platform} data-id={id} data-sound="true">
            {bg && (
              <img class="hero-poster" src={bg.max} alt="" decoding="async" onerror={`this.onerror=null;this.src='${bg.fb}'`} />
            )}
          </div>
          <button type="button" class="sound-toggle" data-sound-toggle aria-pressed="false">
            <span data-sound-label>Sound off</span>
          </button>
        </div>
      </div>
    </section>
  ) : (
    <section class="hero hero-landscape" data-hero>
      <div class="hero-media" data-hero-media data-platform={platform} data-id={id} data-sound="true">
        {bg && (
          <img class="hero-poster" src={bg.max} alt="" decoding="async" onerror={`this.onerror=null;this.src='${bg.fb}'`} />
        )}
      </div>
      <div class="hero-overlay" aria-hidden="true" />
      <div class="container hero-content">
        <p class="eyebrow">{copy.eyebrow}</p>
        <h1>{copy.heading}</h1>
        <div class="hero-actions">
          <a href="#work" class="btn btn-primary">See the work</a>
          <a href="#contact" class="btn btn-secondary">Start a project</a>
        </div>
      </div>
      <button type="button" class="sound-toggle sound-toggle-float" data-sound-toggle aria-pressed="false">
        <span data-sound-label>Sound off</span>
      </button>
    </section>
  )
}

<style>
  .hero {
    position: relative;
    overflow: hidden;
    background: var(--c-black);
  }

  .eyebrow {
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--c-cyan);
    margin-bottom: var(--space-4);
  }

  .hero-actions {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .sound-toggle {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    background: rgba(10, 10, 10, 0.6);
    border: 1px solid var(--c-border);
    color: var(--c-white);
    border-radius: 999px;
    padding: 0.6em 1.1em;
    font-size: 0.85rem;
    cursor: pointer;
    backdrop-filter: blur(6px);
  }

  .sound-toggle[hidden] {
    display: none;
  }

  .sound-toggle:hover {
    border-color: var(--c-cyan);
  }

  .sound-toggle-float {
    position: absolute;
    z-index: 3;
    right: var(--space-6);
    bottom: var(--space-6);
  }

  .hero-poster {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    background-color: #000;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(180deg, rgba(10, 10, 10, 0.62) 0%, rgba(10, 10, 10, 0.58) 40%, rgba(10, 10, 10, 0.92) 100%);
  }

  /* ---------- Portrait (vertical video) hero ---------- */
  .hero-portrait {
    min-height: 88vh;
    display: flex;
    align-items: center;
    padding-block: var(--space-16);
  }

  .hero-glow {
    position: absolute;
    inset: 0;
    z-index: 0;
    background: radial-gradient(circle at 15% 20%, rgba(0, 232, 248, 0.14), transparent 55%),
      radial-gradient(circle at 90% 80%, rgba(248, 24, 120, 0.14), transparent 55%), var(--c-black);
  }

  .hero-grid {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: var(--space-12);
    align-items: center;
  }

  .hero-copy h1 {
    margin-bottom: var(--space-8);
  }

  .hero-video-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  .hero-media-portrait {
    position: relative;
    width: 100%;
    max-width: 300px;
    aspect-ratio: 9 / 16;
    border-radius: 20px;
    overflow: hidden;
    border: 1px solid var(--c-border);
    background: #000;
    box-shadow: 0 24px 70px rgba(0, 0, 0, 0.6);
  }

  /* A vertical video embeds pillar-boxed inside YouTube's 16:9 player;
     over-size the iframe so the centred vertical strip fills the frame. */
  .hero-media-portrait :global(iframe) {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    height: 100%;
    width: 316%; /* (16/9)^2 */
    border: 0;
    pointer-events: none;
  }

  /* ---------- Landscape (full-bleed background) hero ---------- */
  .hero-landscape {
    min-height: 92vh;
    display: flex;
    align-items: flex-end;
  }

  .hero-media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-media :global(iframe) {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 100vw;
    height: 56.25vw;
    min-height: 100%;
    min-width: 177.78vh;
    transform: translate(-50%, -50%);
    border: 0;
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    padding-bottom: var(--space-24);
    max-width: 760px;
  }

  .hero-content h1 {
    margin-bottom: var(--space-8);
  }

  /* ---------- Combined (landscape bg + portrait overlay) hero ---------- */
  .hero-combined {
    min-height: 92vh;
    display: flex;
    align-items: center;
    padding-block: var(--space-16);
  }

  .hero-combined .hero-media-portrait {
    max-width: 280px;
    margin-left: auto;
  }

  @media (max-width: 820px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .hero-video-col {
      order: -1;
    }

    .hero-media-portrait {
      max-width: 240px;
    }

    .hero-combined .hero-media-portrait {
      margin-inline: auto;
    }
  }

  @media (max-width: 640px) {
    .hero-landscape {
      min-height: 70vh;
    }
  }
</style>

<script>
  function initHero() {
    const section = document.querySelector<HTMLElement>('[data-hero]');
    if (!section || section.dataset.bound) return;
    section.dataset.bound = '1';

    const toggleBtn = section.querySelector<HTMLButtonElement>('[data-sound-toggle]');
    const label = section.querySelector<HTMLElement>('[data-sound-label]');
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const medias = Array.from(section.querySelectorAll<HTMLElement>('[data-hero-media]'));
    const win = window as any;

    if (reduceMotion || medias.length === 0) {
      toggleBtn?.setAttribute('hidden', '');
      return;
    }

    let soundPlayer: any = null;
    let soundReady = false;
    let soundPlatform: string | null = null;
    const pendingYT: { id: string; isSound: boolean }[] = [];
    let ytApiRequested = false;

    function flushYT() {
      pendingYT.forEach(({ id, isSound }) => {
        const p = new win.YT.Player(id, {
          events: { onReady: () => { if (isSound) soundReady = true; } },
        });
        if (isSound) soundPlayer = p;
      });
      pendingYT.length = 0;
    }

    function ensureYTApi() {
      if (win.YT && win.YT.Player) {
        flushYT();
      } else if (!ytApiRequested) {
        ytApiRequested = true;
        const s = document.createElement('script');
        s.src = 'https://www.youtube.com/iframe_api';
        document.body.appendChild(s);
        win.onYouTubeIframeAPIReady = flushYT;
      }
    }

    function mount(media: HTMLElement, idx: number) {
      const platform = media.dataset.platform;
      const vid = media.dataset.id;
      const isSound = media.dataset.sound === 'true';
      if (!vid) return;

      if (platform === 'vimeo') {
        const iframe = document.createElement('iframe');
        iframe.src = `https://player.vimeo.com/video/${vid}?background=1&muted=1&loop=1&autoplay=1&title=0&byline=0&portrait=0`;
        iframe.allow = 'autoplay; fullscreen';
        iframe.setAttribute('title', 'Clout & Context showreel');
        media.appendChild(iframe);
        const s = document.createElement('script');
        s.src = 'https://player.vimeo.com/api/player.js';
        s.onload = () => {
          const p = new win.Vimeo.Player(iframe);
          if (isSound) {
            soundPlayer = p;
            soundReady = true;
            soundPlatform = 'vimeo';
          }
        };
        document.body.appendChild(s);
      } else {
        const iframe = document.createElement('iframe');
        const iid = `hero-yt-${idx}`;
        iframe.id = iid;
        const origin = encodeURIComponent(location.origin);
        iframe.src =
          `https://www.youtube-nocookie.com/embed/${vid}` +
          `?autoplay=1&mute=1&loop=1&playlist=${vid}&controls=0&rel=0` +
          `&modestbranding=1&playsinline=1&iv_load_policy=3&disablekb=1&fs=0&enablejsapi=1&origin=${origin}`;
        iframe.allow = 'autoplay; fullscreen; encrypted-media';
        iframe.setAttribute('title', 'Clout & Context showreel');
        media.appendChild(iframe);
        if (isSound) soundPlatform = 'youtube';
        pendingYT.push({ id: iid, isSound });
        ensureYTApi();
      }
    }

    const mountAll = () => medias.forEach((m, i) => mount(m, i));

    if ('IntersectionObserver' in window) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              mountAll();
              observer.disconnect();
            }
          });
        },
        { threshold: 0.05 }
      );
      observer.observe(section);
    } else {
      mountAll();
    }

    toggleBtn?.addEventListener('click', () => {
      if (!soundPlayer || !soundReady) return;
      const isPressed = toggleBtn.getAttribute('aria-pressed') === 'true';
      const setLabel = () => {
        toggleBtn.setAttribute('aria-pressed', String(!isPressed));
        if (label) label.textContent = isPressed ? 'Sound off' : 'Sound on';
      };

      if (soundPlatform === 'vimeo') {
        soundPlayer.setMuted(isPressed).then(setLabel);
      } else {
        if (isPressed) {
          soundPlayer.mute?.();
        } else {
          soundPlayer.unMute?.();
          soundPlayer.setVolume?.(100);
        }
        setLabel();
      }
    });
  }

  initHero();
  document.addEventListener('astro:page-load', initHero);
</script>
