---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE } from '../../data/site';
---

<BaseLayout
  title="Privacy & Cookies"
  description="Privacy policy and cookie notice for cloutandcontext.com."
>
  <section class="legal-section">
    <div class="container">
      <div class="section-heading">
        <span class="eyebrow">Legal</span>
        <h1>Privacy &amp; Cookie Policy</h1>
      </div>

      <div class="legal-copy">
        <p class="text-muted">Last updated: {new Date().toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}</p>

        <h2>Who we are</h2>
        <p>
          This site is operated by Clout &amp; Context Animation Services ("we", "us"). If you have any questions
          about this policy or how your data is handled, contact <a href={`mailto:${SITE.email}`}>{SITE.email}</a>.
        </p>

        <h2>What we collect</h2>
        <p>
          When you submit the enquiry form, we collect the information you provide: name, email address,
          Instagram/artist handle, project type, budget range, deadline and your message. We use this solely to
          respond to your enquiry and, if you become a client, to deliver the project and manage invoicing.
        </p>
        <p>
          We do not sell, rent or share your personal data with third parties for marketing purposes. Form
          submissions are processed by our form provider (Formspree) and, for paying clients, payment and
          invoicing details are processed by Stripe — see their respective privacy policies for how they handle
          data in transit.
        </p>

        <h2>Legal basis &amp; retention</h2>
        <p>
          We process enquiry data on the basis of legitimate interest (responding to a business enquiry you
          initiated) and, for clients, contractual necessity. Enquiry and client data is retained only as long
          as needed for the purposes above, or as required for UK tax and accounting record-keeping.
        </p>

        <h2>Your rights</h2>
        <p>
          Under UK GDPR, you have the right to request access to, correction of, or deletion of your personal
          data, and to object to or restrict how it's processed. To exercise any of these rights, email
          <a href={`mailto:${SITE.email}`}>{SITE.email}</a>.
        </p>

        <h2>Cookies</h2>
        <p>
          This site uses <a href="https://plausible.io/privacy-focused-web-analytics" target="_blank" rel="noopener noreferrer">Plausible</a>,
          a privacy-friendly analytics service that does not use cookies or track individuals across sites,
          and does not collect personal data. No advertising or third-party tracking cookies are set by this site.
          Embedded video players (Vimeo/YouTube) may set their own cookies once you click to play a video —
          this is controlled by the video platform, not by us.
        </p>

        <h2>Changes to this policy</h2>
        <p>
          We may update this policy from time to time. The "last updated" date above reflects the most recent
          revision.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .legal-copy {
    max-width: 72ch;
    display: flex;
    flex-direction: column;
  }

  .legal-copy h2 {
    margin-top: var(--space-8);
    font-size: 1.25rem;
  }
</style>
