---
import BaseLayout from '../layouts/BaseLayout.astro';
import Logo from '../components/Logo.astro';
import { SITE } from '../data/site';
---

<BaseLayout title="Clout & Context" description={SITE.description}>
  <section class="brand-hero">
    <div class="brand-hero-media" data-brand-hero-media data-id="76979871" aria-hidden="true"></div>
    <div class="brand-hero-glow" aria-hidden="true"></div>
    <div class="container brand-hero-content">
      <Logo variant="wordmark" class="hero-wordmark" />
      <h1>UK urban culture, on screen and in motion.</h1>
      <p class="text-muted brand-hero-copy">
        Clout &amp; Context is a channel covering UK independent music, and the cinematic 2D animation
        studio built alongside it — the same eye for the scene, applied to every project.
      </p>
      <div class="brand-hero-actions">
        <a href="/animations/" class="btn btn-primary">Explore the animation studio</a>
        <a href={SITE.social.youtube} class="btn btn-secondary" target="_blank" rel="noopener noreferrer">Watch the channel</a>
      </div>
    </div>
  </section>

  <section id="hub" class="hub-section">
    <div class="container">
      <div class="section-heading">
        <span class="eyebrow">Start here</span>
        <h2>Two sides of the same channel</h2>
      </div>

      <div class="grid grid-2">
        <article class="card hub-card">
          <span class="badge">Animation Studio</span>
          <h3>Animated Music Videos &amp; Social Clips</h3>
          <p class="text-muted">
            Cinematic 2D animation for UK artists and creators — quoted music videos and self-serve
            monthly clip packages. Built by someone who knows the scene from the inside.
          </p>
          <a href="/animations/" class="btn btn-primary">See the work</a>
        </article>

        <article class="card hub-card">
          <span class="badge">The Channel</span>
          <h3>Clout &amp; Context on YouTube</h3>
          <p class="text-muted">
            Coverage of UK urban culture, the artists, and the scene — the audience and credibility
            that every animation project is built on.
          </p>
          <a href={SITE.social.youtube} class="btn btn-primary" target="_blank" rel="noopener noreferrer">Watch the channel</a>
        </article>
      </div>
    </div>
  </section>

  <section class="follow-section">
    <div class="container follow-inner">
      <div class="section-heading">
        <span class="eyebrow">Follow</span>
        <h2>Stay in the loop</h2>
      </div>
      <div class="follow-links">
        <a href={SITE.social.instagram} target="_blank" rel="noopener noreferrer" class="btn btn-secondary">Instagram</a>
        <a href={SITE.social.tiktok} target="_blank" rel="noopener noreferrer" class="btn btn-secondary">TikTok</a>
        <a href={SITE.social.youtube} target="_blank" rel="noopener noreferrer" class="btn btn-secondary">YouTube</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .brand-hero {
    position: relative;
    overflow: hidden;
    min-height: 78vh;
    display: flex;
    align-items: center;
    background: var(--c-black);
  }

  .brand-hero-media {
    position: absolute;
    inset: 0;
    z-index: 0;
    background: #000;
  }

  .brand-hero-media :global(iframe) {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 100vw;
    height: 56.25vw;
    min-height: 100%;
    min-width: 177.78vh;
    transform: translate(-50%, -50%);
    border: 0;
    pointer-events: none;
  }

  .brand-hero-glow {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(180deg, rgba(10, 10, 10, 0.68) 0%, rgba(10, 10, 10, 0.8) 100%),
      radial-gradient(circle at 20% 20%, rgba(0, 232, 248, 0.14), transparent 55%),
      radial-gradient(circle at 85% 75%, rgba(248, 24, 120, 0.14), transparent 55%);
  }

  .brand-hero-content {
    position: relative;
    z-index: 2;
    max-width: 760px;
  }

  .brand-hero-content :global(.hero-wordmark) {
    max-width: 380px;
    margin-bottom: var(--space-4);
  }

  .brand-hero-content h1 {
    margin-top: var(--space-8);
  }

  .brand-hero-copy {
    max-width: 60ch;
    font-size: 1.1rem;
    margin-bottom: var(--space-8);
  }

  .brand-hero-actions {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .hub-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .hub-card .badge {
    align-self: flex-start;
    margin-bottom: var(--space-2);
  }

  .hub-card .btn {
    align-self: flex-start;
    margin-top: var(--space-2);
  }

  .follow-section {
    background: var(--c-surface);
  }

  .follow-links {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }
</style>

<script>
  function initBrandHero() {
    const media = document.querySelector<HTMLElement>('[data-brand-hero-media]');
    if (!media || media.dataset.bound) return;
    media.dataset.bound = '1';
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const id = media.dataset.id;
    if (!id) return;

    const mount = () => {
      const iframe = document.createElement('iframe');
      iframe.src = `https://player.vimeo.com/video/${id}?background=1&muted=1&loop=1&autoplay=1`;
      iframe.allow = 'autoplay; fullscreen';
      iframe.setAttribute('title', 'Clout & Context');
      media.appendChild(iframe);
    };

    if ('IntersectionObserver' in window) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              mount();
              observer.disconnect();
            }
          });
        },
        { threshold: 0.1 }
      );
      observer.observe(media);
    } else {
      mount();
    }
  }

  initBrandHero();
  document.addEventListener('astro:page-load', initBrandHero);
</script>
