---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE } from '../../data/site';
---

<BaseLayout
  title="About"
  description="Clout & Context Animation is run by the person behind the Clout & Context channel — cinematic animation for UK independent artists."
>
  <section class="about-section">
    <div class="container">
      <div class="section-heading">
        <span class="eyebrow">About</span>
        <h1>Animation from inside the scene</h1>
      </div>

      <div class="about-copy">
        <p>
          Clout &amp; Context Animation is run alongside the Clout &amp; Context channel — built by someone who
          covers UK independent music every day, not an animator taking on music videos as a side category.
        </p>
        <p>
          That's the credential: knowing the scene, the artists and the sound, and building animation that holds
          an audience for a full track rather than a few seconds of scroll.
        </p>
        <p>
          Every project — a £300 visualiser or a £3,000 cinematic piece — gets the same attention to what actually
          gets an artist's release watched, shared and remembered.
        </p>
      </div>

      <div class="about-cta">
        <a href="/music-videos/" class="btn btn-primary">See music video packages</a>
        <a href="/#contact" class="btn btn-secondary">Start a project</a>
      </div>

      <p class="text-muted contact-line">
        Get in touch: <a href={`mailto:${SITE.email}`}>{SITE.email}</a> ·
        <a href={SITE.social.instagram} target="_blank" rel="noopener noreferrer">{SITE.handle}</a>
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .about-copy {
    max-width: 68ch;
  }

  .about-copy p {
    font-size: 1.05rem;
  }

  .about-cta {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
    margin: var(--space-8) 0;
  }

  .contact-line {
    margin-top: var(--space-4);
  }
</style>
